SAVE_THAT_TUNE_API_KEY=change-me-long-random-key
SAVE_THAT_TUNE_DB=data/actions.db
SAVE_THAT_TUNE_NAS_ROOT=/volume1/music/inbox
SAVE_THAT_TUNE_DEADDISC_CACHE=data/deaddisc_cache.json
SAVE_THAT_TUNE_PHISHNET_CACHE=data/phishnet_cache.json

# SMTP (optional but recommended for notifications)
SAVE_THAT_TUNE_SMTP_HOST=smtp.gmail.com
SAVE_THAT_TUNE_SMTP_PORT=587
SAVE_THAT_TUNE_SMTP_USERNAME=you@example.com
SAVE_THAT_TUNE_SMTP_PASSWORD=app-password
SAVE_THAT_TUNE_MAIL_FROM=you@example.com
SAVE_THAT_TUNE_MAIL_TO=you@example.com

# Spotify API (required for Spotify save)
SAVE_THAT_TUNE_SPOTIFY_CLIENT_ID=
SAVE_THAT_TUNE_SPOTIFY_CLIENT_SECRET=
SAVE_THAT_TUNE_SPOTIFY_REFRESH_TOKEN=

# phish.in optional key
SAVE_THAT_TUNE_PHISHIN_API_KEY=
